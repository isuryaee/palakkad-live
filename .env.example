# ============================================================================
# DATABASE (PostgreSQL via Prisma)
# ============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/livepalakkad"

# ============================================================================
# NEXTAUTH.JS (Admin Authentication)
# ============================================================================
# NEXTAUTH_SECRET: Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# NextAuth adapter (database)
AUTH_TRUST_HOST="true"

# ============================================================================
# ADMIN CREDENTIALS (seeded on first run)
# ============================================================================
# Default admin account email (must match your email)
ADMIN_EMAIL="srr6vv@gmail.com"
# Default admin account password (set to a secure password)
ADMIN_PASSWORD="change-me-to-a-strong-password"

# ============================================================================
# SITE CONFIGURATION
# ============================================================================
SITE_NAME="LivePalakkad"
SITE_URL="https://livepalakkad.com"
SITE_PHONE="90745 00360"
SITE_EMAIL="mailstudiocity@gmail.com"
SITE_FACEBOOK="https://www.facebook.com/livepalakkadnews/"
SITE_INSTAGRAM="@livepalakkad"

# ============================================================================
# WEATHER API (IMD - India Meteorological Department)
# ============================================================================
# If using OpenWeatherMap instead, set this instead:
# WEATHER_API_KEY="your-openweathermap-api-key"
# WEATHER_API_PROVIDER="openweathermap"

# For IMD integration (if API key needed):
IMD_API_KEY="optional-imd-api-key"

# ============================================================================
# FILE STORAGE
# ============================================================================
# Local uploads folder (relative to project root)
UPLOADS_DIR="/uploads"

# Optional: For future S3/Cloudinary migration
# S3_BUCKET_NAME="your-bucket"
# S3_REGION="your-region"
# S3_ACCESS_KEY_ID="your-access-key"
# S3_SECRET_ACCESS_KEY="your-secret-key"

# ============================================================================
# PUSH NOTIFICATIONS (Web Push / Firebase)
# ============================================================================
# VAPID keys for Web Push Notifications
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# Optional: Firebase Cloud Messaging
# FIREBASE_API_KEY="your-firebase-api-key"
# FIREBASE_PROJECT_ID="your-firebase-project-id"

# ============================================================================
# ADMIN PANEL ROUTE (hidden URL)
# ============================================================================
# Non-obvious path for admin panel, not linked in public nav
# Do not change after deployment (users will be unable to access admin)
NEXT_PUBLIC_ADMIN_PATH="/desk"

# ============================================================================
# SECURITY
# ============================================================================
# CAPTCHA for public forms (optional, for newsletter/comments)
# HCAPTCHA_SECRET="your-hcaptcha-secret-key"
# NEXT_PUBLIC_HCAPTCHA_SITE_KEY="your-hcaptcha-site-key"

# ============================================================================
# ANALYTICS (optional)
# ============================================================================
# GOOGLE_ANALYTICS_ID="UA-XXXXXXXXX-X"
# NEXT_PUBLIC_GTAG_ID="G-XXXXXXXXXX"

# ============================================================================
# LOGGING & MONITORING (optional)
# ============================================================================
# NODE_ENV="production" or "development"
NODE_ENV="development"

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
# Skip email verification during development
SKIP_EMAIL_VERIFICATION="false"

# Enable debug logging
DEBUG="livepalakkad:*"
