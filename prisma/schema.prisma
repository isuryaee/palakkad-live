// LivePalakkad News Platform - Prisma Schema
// Full-stack bilingual hyperlocal news website for Palakkad district, Kerala

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH MODELS (NextAuth)
// ============================================================================

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? 
  access_token       String? 
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? 
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// USER & ROLE-BASED ACCESS CONTROL
// ============================================================================

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?    // hashed password for email/password auth
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastActiveAt  DateTime   @default(now())
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret String?

  accounts     Account[]
  sessions     Session[]
  userRoles    UserRole[]
  articles     Article[]       @relation("author")
  comments     Comment[]
  notifications PushNotification[]

  @@index([email])
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "can:create:articles"
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([name])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "Reporter", "Sub-Editor", "Location Correspondent — Mannarkkad"
  description String?
  isSystem    Boolean  @default(false) // true for built-in roles (Full Admin, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([name])
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ============================================================================
// CONTENT MODELS
// ============================================================================

model Section {
  id          String   @id @default(cuid())
  name        String   @unique
  nameMal     String   @unique // Malayalam name
  slug        String   @unique
  description String?
  descriptionMal String?
  icon        String?  // emoji or icon identifier
  heroImage   String?  // URL to hero image
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories Category[]

  @@index([slug])
  @@index([order])
  @@index([isActive])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  nameMal     String   @unique // Malayalam name
  slug        String   @unique
  description String?
  descriptionMal String?
  icon        String?  // emoji or icon identifier
  order       Int      @default(0)
  heroImage   String?  // URL to hero image
  sectionId   String?
  section     Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles Article[]

  @@index([slug])
  @@index([order])
  @@index([sectionId])
}

model Location {
  id          String   @id @default(cuid())
  name        String   @unique
  nameMal     String   @unique // Malayalam name
  slug        String   @unique
  description String?
  descriptionMal String?
  heroImage   String?  // URL to hero image
  latitude    Float?
  longitude   Float?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles Article[]

  @@index([slug])
  @@index([order])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  articles ArticleTag[]

  @@index([slug])
}

model Article {
  id                String   @id @default(cuid())
  title             String
  titleMal          String?  // Malayalam title
  slug              String   @unique
  content           String   // Rich text HTML
  contentMal        String?  // Malayalam content
  excerpt           String?
  excerptMal        String?
  featuredImage     String?  // URL to featured image
  status            String   @default("DRAFT") // DRAFT, SCHEDULED, PUBLISHED, ARCHIVED
  published         Boolean  @default(false)
  isBreaking        Boolean  @default(false)
  publishedAt       DateTime?
  scheduledFor      DateTime? // For scheduled posts
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
  
  // SEO fields
  seoTitle          String?
  seoDescription    String?
  seoKeywords       String?
  canonicalUrl      String?
  ogImage           String?
  
  // Author & metadata
  authorId          String
  author            User     @relation("author", fields: [authorId], references: [id])
  categoryId        String?
  category          Category? @relation(fields: [categoryId], references: [id])
  locationId        String?
  location          Location? @relation(fields: [locationId], references: [id])
  
  // Relations
  images            ArticleImage[]
  videos            ArticleVideo[]
  tags              ArticleTag[]
  comments          Comment[]
  relatedArticles   ArticleRelation[] @relation("article")
  relatedFrom       ArticleRelation[] @relation("related")

  @@index([slug])
  @@index([published])
  @@index([publishedAt])
  @@index([categoryId])
  @@index([locationId])
  @@index([authorId])
  @@index([isBreaking])
}

// ArticleStatus: DRAFT, SCHEDULED, PUBLISHED, ARCHIVED

model ArticleImage {
  id        String   @id @default(cuid())
  articleId String
  imageUrl  String
  caption   String?
  alt       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model ArticleVideo {
  id        String   @id @default(cuid())
  articleId String
  embedUrl  String   // Embed URL for YouTube/Facebook/Instagram
  videoType String   // "youtube", "facebook", "instagram"
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model ArticleTag {
  id        String   @id @default(cuid())
  articleId String
  tagId     String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([articleId, tagId])
  @@index([articleId])
  @@index([tagId])
}

model ArticleRelation {
  id              String   @id @default(cuid())
  articleId       String
  relatedArticleId String

  article Article @relation("article", fields: [articleId], references: [id], onDelete: Cascade)
  relatedArticle Article @relation("related", fields: [relatedArticleId], references: [id], onDelete: Cascade)

  @@unique([articleId, relatedArticleId])
  @@index([articleId])
  @@index([relatedArticleId])
}

// ============================================================================
// LIVE UPDATES
// ============================================================================

model LiveUpdateThread {
  id          String   @id @default(cuid())
  title       String
  titleMal    String?
  slug        String   @unique
  isClosed    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  closedAt    DateTime?

  updates LiveUpdateEntry[]

  @@index([isClosed])
  @@index([createdAt])
}

model LiveUpdateEntry {
  id        String   @id @default(cuid())
  threadId  String
  content   String  
  contentMal String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  thread LiveUpdateThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([createdAt])
}

// ============================================================================
// COMMENTS & MODERATION
// ============================================================================

model Comment {
  id        String   @id @default(cuid())
  articleId String
  userId    String
  content   String  
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED, SPAM
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([userId])
  @@index([status])
}

// CommentStatus: PENDING, APPROVED, REJECTED, SPAM

// ============================================================================
// ADVERTISEMENTS
// ============================================================================

model Advertisement {
  id          String   @id @default(cuid())
  name        String
  creative    String?  // URL to image/creative file
  link        String?
  placement   String   // "header", "sidebar", "footer", "in-feed", etc.
  isActive    Boolean  @default(false)
  startDate   DateTime?
  endDate     DateTime?
  impressions Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([placement])
}

// ============================================================================
// REPORTERS (AUTHOR PROFILES)
// ============================================================================

model Reporter {
  id          String   @id @default(cuid())
  name        String
  bio         String?
  photo       String?  // URL to profile photo
  social      String?  // JSON string: { twitter, facebook, linkedin, etc. }
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

// ============================================================================
// MEDIA LIBRARY
// ============================================================================

model MediaLibrary {
  id        String   @id @default(cuid())
  filename  String
  url       String
  fileType  String   // "image", "video"
  mimeType  String
  size      Int      // in bytes
  altText   String?
  tags      String?  // comma-separated tags
  createdAt DateTime @default(now())

  @@index([fileType])
}

// ============================================================================
// NEWSLETTERS & SUBSCRIPTIONS
// ============================================================================

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  status    String   @default("ACTIVE") // ACTIVE, UNSUBSCRIBED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// SubscriptionStatus: ACTIVE, UNSUBSCRIBED

// ============================================================================
// PUSH NOTIFICATIONS
// ============================================================================

model PushNotification {
  id        String   @id @default(cuid())
  userId    String?  // null = broadcast to all
  title     String
  body      String
  icon      String?
  badge     String?
  tag       String?  // "breaking", "weather", "custom", etc.
  link      String?
  sentAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tag])
}

// ============================================================================
// POLLS
// ============================================================================

model Poll {
  id        String   @id @default(cuid())
  question  String
  questionMal String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options PollOption[]
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  text   String
  order  Int    @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String   @id @default(cuid())
  optionId  String
  createdAt DateTime @default(now())

  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([optionId])
}

// ============================================================================
// EXPLORE PALAKKAD (TOURISM)
// ============================================================================

model PlaceToVisit {
  id          String   @id @default(cuid())
  name        String
  nameMal     String?
  slug        String   @unique
  category    String   // "attraction", "hidden-gem", "waterfall", "temple", "mosque", "museum", "park", etc.
  description String? 
  descriptionMal String?
  image       String?
  latitude    Float?
  longitude   Float?
  mapEmbed    String?  // Google Maps embed URL
  openingHours String?
  entryFee    String?
  bestTime    String?
  facilities  String?  // comma-separated: parking, restroom, food, etc.
  nearbyAttractions String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([slug])
}

model TravelGuide {
  id          String   @id @default(cuid())
  title       String
  titleMal    String?
  slug        String   @unique
  type        String   // "oneday", "weekend", "trekking", "camping", "culture", "food", "history", "festivals", "traditions", "artforms", "music", "personalities"
  description String? 
  descriptionMal String?
  content     String? 
  contentMal  String? 
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([slug])
}

// ============================================================================
// SETTINGS & CONFIGURATION
// ============================================================================

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@index([key])
}

// ============================================================================
// ANALYTICS
// ============================================================================

model PageView {
  id        String   @id @default(cuid())
  articleId String?
  pageUrl   String
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([articleId])
  @@index([createdAt])
}
